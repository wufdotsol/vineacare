rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default: denny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection: Allow users to read/write their own data
    match /users/{userId} {
      allow read: if true; // Allow public viewing of profiles if needed, or change to auth
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Posts collection: Allow reading and authenticated posting
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorUid;
    }
  }
}