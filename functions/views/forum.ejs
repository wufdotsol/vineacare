<%- include('partials/header') %>

<main id="main" class="forum-main-container bg-light" style="min-height: 100vh;">
  <div class="container-fluid py-4" style="margin-top: 60px;">
      <div id="logged-in-user-data" data-uid="<%= typeof uid !== 'undefined' ? uid : '' %>" hidden></div>
      
      <!-- Content Wrapper -->
      <div id="forum-content-block" class="row g-4 justify-content-center">
        
        <!-- Left Column: Sidebar -->
        <div class="col-lg-3 d-none d-lg-block left-sidebar">
           <div class="sidebar-content position-sticky" style="top: 100px;">
             <!-- Desktop Search Bar -->
             <div class="search-bar-container mb-4 shadow-sm rounded">
               <div class="input-group">
                 <span class="input-group-text bg-white border-0"><i class="bi bi-search"></i></span>
                 <input type="text" class="form-control bg-white border-0 shadow-none ps-0" placeholder="Search Users & Friends">
                 <span class="input-group-text bg-white border-0"><i class="bi bi-x-circle text-muted d-none clear-btn" style="cursor:pointer;"></i></span>
               </div>
             </div>
             <!-- Profile Summary -->
             <div class="profile-summary mb-4 p-3 bg-white shadow-sm rounded d-flex align-items-center hover-effect">
                <img src="https://ui-avatars.com/api/?name=Guest&background=random" id="left-pfp" class="rounded-circle me-3" width="50" height="50" alt="Profile" style="object-fit:cover;">
                <div style="line-height:1.2;">
                  <h6 class="mb-1 fw-bold text-dark" id="left-name">Loading...</h6>
                  <small class="text-muted" id="left-username">@loading</small>
                </div>
                <div class="ms-auto"><span class="d-inline-block rounded-circle bg-success" style="width: 10px; height: 10px;" title="Online"></span></div>
             </div>
             <!-- Navigation -->
             <div class="list-group list-group-flush shadow-sm rounded bg-white overflow-hidden left-nav-links">
               <a href="#" class="list-group-item list-group-item-action border-0 py-3 fw-medium d-flex align-items-center"><i class="bi bi-person-fill-add me-3 fs-5 text-primary"></i> Received Friend Requests</a>
               <a href="#" class="list-group-item list-group-item-action border-0 py-3 fw-medium d-flex align-items-center"><i class="bi bi-envelope-fill me-3 fs-5 text-info"></i> New Messages</a>
               <a href="#" class="list-group-item list-group-item-action border-0 py-3 fw-medium d-flex align-items-center"><i class="bi bi-hourglass-split me-3 fs-5 text-warning"></i> Pending Requests</a>
               <a href="#" class="list-group-item list-group-item-action border-0 py-3 fw-medium d-flex align-items-center"><i class="bi bi-people-fill me-3 fs-5 text-success"></i> My Friends</a>
               <a href="#" class="list-group-item list-group-item-action border-0 py-3 fw-medium d-flex align-items-center"><i class="bi bi-bookmark-fill me-3 fs-5 text-secondary"></i> My Bookmarks</a>
               <a href="#" class="list-group-item list-group-item-action border-0 py-3 text-danger fw-bold d-flex align-items-center" id="side-logout-btn"><i class="bi bi-box-arrow-right me-3 fs-5"></i> Logout</a>
             </div>
           </div>
        </div>

        <!-- Middle Column: Feed -->
        <div class="col-lg-5 col-md-8 middle-feed">
           <!-- Top Nav (Fixed inside Middle Column) -->
           <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded rounded-pill">
              <div class="ms-2">
                 <img src="/assets/img/logos/vinea_care_clr.png" height="35" alt="Vinea Care Logo">
              </div>
              <div class="middle-search w-50 pe-2">
                 <div class="input-group input-group-sm rounded-pill overflow-hidden border">
                   <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                   <input type="text" class="form-control bg-white border-0 shadow-none" placeholder="Search Ex: @user">
                 </div>
              </div>
           </div>

           <!-- Tabs -->
           <ul class="nav nav-pills nav-fill mb-4 bg-white shadow-sm rounded-pill p-1" id="feedTabs">
             <li class="nav-item">
               <a class="nav-link active rounded-pill fw-bold" data-tab="feed" href="#">My Feed</a>
             </li>
             <li class="nav-item">
               <a class="nav-link rounded-pill fw-bold text-muted" data-tab="bookmarks" href="#">Bookmarks</a>
             </li>
             <li class="nav-item">
               <a class="nav-link rounded-pill fw-bold text-muted" data-tab="posts" href="#">My Posts</a>
             </li>
           </ul>

           <!-- Create Post -->
           <div class="create-post-section mb-4 p-4 shadow-sm bg-white" style="border-radius: 15px;">
              <form id="compose-form">
                <div class="d-flex mb-3">
                  <img src="https://ui-avatars.com/api/?name=Guest&background=random" id="compose-pfp" class="rounded-circle me-3" width="40" height="40" alt="PFP" style="object-fit:cover;">
                  <textarea class="form-control border-0 shadow-none bg-light rounded-4 px-3 py-3" id="post-text" placeholder="What's happening?" rows="3" style="resize:none;"></textarea>
                </div>
                <div class="d-flex justify-content-between align-items-center px-1">
                   <div class="media-preview" id="media-preview-container"></div>
                   <div class="d-flex gap-3">
                     <button type="button" class="btn btn-light rounded-circle text-primary shadow-sm"><i class="bi bi-image"></i></button>
                     <button type="submit" class="btn btn-primary px-4 rounded-pill fw-bold shadow-sm">Post</button>
                   </div>
                </div>
              </form>
           </div>
           
           <!-- Feed Container -->
           <div id="feed-container" class="feed-container pb-5">
             <div class="text-center text-muted py-5" id="feed-loading">
               <div class="spinner-border text-primary" role="status"></div>
             </div>
           </div>
        </div>

        <!-- Right Column: Profile & Comments -->
        <div class="col-lg-3 col-md-4 right-sidebar">
           <div class="sidebar-content position-sticky" id="right-column-content" style="top: 100px;">
              
              <!-- Default View: Current User Profile -->
              <div id="right-default-profile" class="right-view-panel">
                <!-- Mini Profile Card -->
                <div class="text-center mb-4 p-4 bg-white shadow-sm rounded-4 position-relative overflow-hidden">
                   <!-- Background Banner -->
                   <div class="bg-primary position-absolute top-0 start-0 w-100" style="height: 60px; opacity: 0.1;"></div>
                   <img src="https://ui-avatars.com/api/?name=Guest&background=random" id="right-pfp" class="rounded-circle mb-3 border border-4 border-white shadow-sm position-relative mt-2" width="90" height="90" style="object-fit:cover;">
                   <h5 class="fw-bold mb-0 text-dark" id="right-name">Loading...</h5>
                   <p class="text-muted mb-3" id="right-username">@loading</p>
                   
                   <!-- Inline Tab Navigation -->
                   <ul class="nav nav-pills justify-content-center right-side-pills mt-3" style="gap: 5px;">
                     <li class="nav-item"><a class="nav-link active rounded-pill px-3 py-1 fw-bold fs-7" data-target="inbox" href="#">Inbox</a></li>
                     <li class="nav-item"><a class="nav-link text-muted rounded-pill px-3 py-1 fw-bold fs-7" data-target="friends" href="#">Friends</a></li>
                     <li class="nav-item"><a class="nav-link text-muted rounded-pill px-3 py-1 fw-bold fs-7" data-target="posts" href="#">Posts</a></li>
                   </ul>
                </div>

                <!-- Dynamic Right Content Container (e.g. Inbox Chats) -->
                <div id="right-tab-content" class="scrollable-right bg-white shadow-sm rounded-4 p-2" style="max-height: 50vh; overflow-y:auto;">
                   <!-- Content loaded dynamically based on pill selection -->
                   <div class="text-center text-muted py-4"><small>Loading...</small></div>
                </div>
              </div>

              <!-- Contextual View: Comment Section (Hidden initially) -->
              <div id="right-comment-section" class="right-view-panel d-none bg-white shadow-sm rounded-4 p-3 h-100 d-flex flex-column" style="max-height: 80vh;">
                 <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                   <h5 class="fw-bold mb-0 text-dark">Comments</h5>
                   <button class="btn btn-sm btn-light rounded-circle" id="close-comments-btn"><i class="bi bi-x-lg"></i></button>
                 </div>
                 
                 <!-- Comments List -->
                 <div id="comments-list" class="flex-grow-1 overflow-auto mb-3 pe-2" style="scrollbar-width: thin;">
                    <!-- Insert comments -->
                 </div>

                 <!-- Comment Form -->
                 <form id="right-comment-form" class="mt-auto border-top pt-3">
                    <input type="hidden" id="active-comment-post-id">
                    <div class="input-group">
                      <input class="form-control rounded-pill bg-light border-0 shadow-none ps-3" id="right-comment-text" placeholder="Write a reply..." required autocomplete="off">
                      <button class="btn btn-primary rounded-circle ms-2" type="submit" style="width:40px;height:40px;"><i class="bi bi-send-fill text-white"></i></button>
                    </div>
                 </form>
              </div>
           </div>
        </div>

      </div>

      <!-- Auth Prompt (hidden by default since auth check is stripped) -->
      <div id="auth-prompt-block" class="row justify-content-center d-none">
        <div class="col-md-6">
          <div class="alert bg-white text-center shadow rounded-4 py-5 border-0">
            <h1 class="fw-bold mb-3 text-dark">Welcome to the Community</h1>
            <p class="mb-4 text-muted fs-5">Connect with peers, share your thoughts, and stay updated. Sign in to start exploring.</p>
            <button class="btn btn-primary btn-lg rounded-pill px-5 shadow auth-trigger-btn" id="central-login-btn">Sign in with Google</button>
          </div>
        </div>
      </div>
      
  </div>
</main>

<link href="/assets/css/forum_new.css" rel="stylesheet">
<script type="module" src="/assets/js/forumUI.js"></script>

<%- include('partials/footer') %>