<%- include('partials/header') %>

<main id="main">

  <!-- ======= Breadcrumbs ======= -->
  <section id="breadcrumbs" class="breadcrumbs">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center">
        <h2>User Dashboard</h2>
        <ol>
          <li><a href="/">Home</a></li>
          <li>Profile</li>
        </ol>
      </div>
    </div>
  </section><!-- End Breadcrumbs -->

  <section class="profile-section">
    <div class="container" data-aos="fade-up">
      <div class="row">
        <!-- Sidebar / Navigation Tabs -->
        <div class="col-lg-3">
          <div class="profile-sidebar shadow-sm rounded p-4 mb-4">
            <div class="text-center mb-4">
              <div class="profile-img-container">
                <img id="profile-pic-large" src="/assets/img/team/team-1.jpg" alt="" class="img-fluid rounded-circle shadow">
                <div class="img-edit-overlay">
                  <i class="bi bi-camera"></i>
                </div>
              </div>
              <h4 id="display-name-sidebar" class="mt-3 mb-0">User Name</h4>
              <p id="username-sidebar" class="text-muted small">@username</p>
            </div>
            
            <ul class="nav flex-column profile-nav" id="profileTab" role="tablist">
              <li class="nav-item">
                <button class="nav-link active w-100 text-start" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab">
                  <i class="bi bi-person-gear me-2"></i> Account Settings
                </button>
              </li>
              <li class="nav-item">
                <button class="nav-link w-100 text-start" id="inbox-tab" data-bs-toggle="tab" data-bs-target="#inbox" type="button" role="tab">
                  <i class="bi bi-envelope me-2"></i> Inbox <span class="badge bg-primary rounded-pill badge-notification" id="inbox-count">0</span>
                </button>
              </li>
              <li class="nav-item">
                <button class="nav-link w-100 text-start" id="notifications-tab" data-bs-toggle="tab" data-bs-target="#notifications" type="button" role="tab">
                  <i class="bi bi-bell me-2"></i> Notifications <span class="badge bg-danger rounded-pill badge-notification" id="notif-count">0</span>
                </button>
              </li>
              <li class="mt-4">
                <hr>
                <button id="logout-btn" class="btn btn-outline-danger w-100 text-start">
                  <i class="bi bi-box-arrow-right me-2"></i> Logout
                </button>
              </li>
            </ul>
          </div>
        </div>

        <!-- Main Content Area -->
        <div class="col-lg-9">
          <div class="tab-content profile-content shadow-sm rounded p-4" id="profileTabContent">
            
            <!-- Settings Tab -->
            <div class="tab-pane fade show active" id="settings" role="tabpanel">
              <h3 class="section-title">Account Settings</h3>
              <form id="profile-form" class="mt-4">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label for="displayName" class="form-label">Display Name</label>
                    <input type="text" class="form-control" id="displayName" placeholder="e.g. John Doe">
                  </div>
                  <div class="col-md-6">
                    <label for="username" class="form-label">Username</label>
                    <div class="input-group">
                      <span class="input-group-text">@</span>
                      <input type="text" class="form-control" id="username" placeholder="johndoe123">
                    </div>
                  </div>
                  <div class="col-12">
                    <label for="profilePic" class="form-label">Profile Picture URL</label>
                    <input type="url" class="form-control" id="profilePic" placeholder="https://example.com/photo.jpg">
                  </div>
                  <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-primary px-4 py-2">Save Changes</button>
                    <span id="save-status" class="ms-3 text-success d-none"><i class="bi bi-check-circle-fill"></i> Saved!</span>
                  </div>
                </div>
              </form>
            </div>

            <!-- Inbox Tab -->
            <div class="tab-pane fade" id="inbox" role="tabpanel">
              <h3 class="section-title">Inbox</h3>
              <div id="inbox-list" class="mt-4">
                <div class="text-center py-5 text-muted">
                  <i class="bi bi-chat-dots" style="font-size: 3rem;"></i>
                  <p class="mt-3">Your inbox is empty.</p>
                </div>
              </div>
            </div>

            <!-- Notifications Tab -->
            <div class="tab-pane fade" id="notifications" role="tabpanel">
              <h3 class="section-title">Notifications</h3>
              <div id="notifications-list" class="mt-4">
                <div class="text-center py-5 text-muted">
                  <i class="bi bi-bell-slash" style="font-size: 3rem;"></i>
                  <p class="mt-3">No new notifications.</p>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

</main><!-- End #main -->

<!-- Modal for messages / alerts -->
<div class="modal fade" id="alertModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title">Notification</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center py-4" id="alertModalBody">
        <!-- Message goes here -->
      </div>
    </div>
  </div>
</div>

<link href="/assets/css/profile.css" rel="stylesheet">
<script type="module" src="/assets/js/profile.js"></script>

<%- include('partials/footer') %>
